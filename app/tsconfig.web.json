{
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "verbatimModuleSyntax": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "esnext",
    "jsx": "react-jsx",
    "lib": ["esnext", "dom", "dom.iterable"],
    "composite": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmit": false,
    "outDir": "./out/renderer",
    "rootDir": "./src/renderer",
    "baseUrl": ".",
    "paths": {
      "@data/*": ["../data/*"]
    }
  },
  "include": ["src/renderer/src/**/*.ts", "src/renderer/src/**/*.tsx", "src/renderer/src/**/*.json", "src/preload/**/*.d.ts"]
}
